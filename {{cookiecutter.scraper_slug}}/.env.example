# Local-only env vars. CI gets these from GH Actions secrets/variables;
# the production worker gets them from Dokploy service env.
# Copy to `.env` (gitignored) and fill in for laptop development.

# --- Provided by the Prefect worker on production ---
# PG (scraper-portfolio-pg). libpq-standard names.
PGHOST=scraperportfoliopg
PGPORT=5432
PGUSER=portfolio
# PGPASSWORD=...
PGDATABASE={{ cookiecutter.pg_database }}

# Supabase pooler (only needed if the warehouse mirror runs against Supabase)
# SUPABASE_PG_HOST=
# SUPABASE_PG_PORT=6543
# SUPABASE_PG_USER=postgres.<project-ref>
# SUPABASE_PG_DATABASE=postgres
# SUPABASE_PG_PASSWORD=          # OR provide _B64 variant if value has $ etc.
# SUPABASE_PG_PASSWORD_B64=

# --- Provided by CI for Prefect deploy ---
# PREFECT_API_URL=https://prefect.statdesk.com.au/api
# PREFECT_API_AUTH_STRING=admin:<password>

# --- Optional: Slack notifications (no-op when unset) ---
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
